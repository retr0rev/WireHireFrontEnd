{
  "name": "wirehire",
  "private": true,
  "scripts": {
    "dev:public": "pnpm --filter @wirehire/public dev",
    "dev:employer": "pnpm --filter @wirehire/employer dev",
    "dev:admin": "pnpm --filter @wirehire/admin dev",
    "build:public": "pnpm --filter @wirehire/public build",
    "build:employer": "pnpm --filter @wirehire/employer build",
    "build:admin": "pnpm --filter @wirehire/admin build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
