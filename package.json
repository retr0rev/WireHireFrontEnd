{
  "name": "wirehire",
  "private": true,
  "scripts": {
    "dev:public": "pnpm --filter @wirehire/public dev",
    "dev:dashboard": "pnpm --filter @wirehire/dashboard dev",
    "build:public": "pnpm --filter @wirehire/public build",
    "build:dashboard": "pnpm --filter @wirehire/dashboard build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
